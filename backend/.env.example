# Configuration du serveur
PORT=3000
NODE_ENV=development

# Configuration de la base de données
DB_PATH=./data/surveillance.db

# Configuration JWT (CHANGEZ CECI EN PRODUCTION)
JWT_SECRET=votre-secret-super-securise-a-changer-en-production
JWT_EXPIRES_IN=24h

# Configuration WebSocket
WS_CORS_ORIGIN=*

# Configuration RSSI
RSSI_TX_POWER=-59
RSSI_ENVIRONMENT_FACTOR=2
PERIMETER_THRESHOLD=-95

# Configuration des alertes
ALERT_CHECK_INTERVAL=5000
ANOMALY_DETECTION_THRESHOLD=2

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
